# OBSYD Configuration
# Copy to .env and fill in your keys: cp .env.example .env

# ─── Required ────────────────────────────────────────────────────────────────

# Environment: "development" or "production".
# In production the app REFUSES to start with default/change-me secrets.
ENVIRONMENT=development

# App secrets — MUST change before production (use: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-random-64-char-string
JWT_SECRET=change-me-to-random-64-char-string

# ─── Power & gas data (what the desk actually shows) ─────────────────────────
# Both free. The app runs without them but shows no data until they're set.

# ENTSO-E Transparency Platform — prices/load/generation/flows/outages. Free but
# manual: register at https://transparency.entsoe.eu/ then email
# transparency@entsoe.eu to request Restful API access (~1-3 day grant).
# ENTSOE_API_TOKEN=
# CCGT fleet electrical efficiency for power-burn→gas (default 0.50)
# GAS_CCGT_EFFICIENCY=0.50

# GIE — EU gas storage (AGSI) + LNG (ALSI). One free key covers both.
# Register: https://agsi.gie.eu/  (account → API key). Sent as the x-key header.
# GIE_API_KEY=

# ─── Optional ────────────────────────────────────────────────────────────────

# Database (default: SQLite in project root)
# DATABASE_URL=sqlite:///./obsyd.db

# ── Dormant non-power verticals (oil / macro / maritime-AIS): disabled in the
#    default power-only config — set only if you re-enable one of those collectors.
# EIA — US petroleum stats (free, https://www.eia.gov/opendata/register.php)
# EIA_API_KEY=
# FRED — macro series (free, https://fred.stlouisfed.org/docs/api/api_key.html)
# FRED_API_KEY=
# AIS Stream — vessel positions (free, https://aisstream.io/)
# AISSTREAM_API_KEY=
# AISHub — fallback AIS source (requires own AIS station, https://www.aishub.net/)
# AISHUB_API_KEY=
# AISHUB_USERNAME=

# Alpha Vantage — price fallback (free, https://www.alphavantage.co/support/#api-key)
# ALPHA_VANTAGE_API_KEY=

# Twelve Data — price fallback (free tier, https://twelvedata.com/)
# TWELVEDATA_API_KEY=

# Finnhub — financial news headlines (free, https://finnhub.io/)
# FINNHUB_API_KEY=

# NASA FIRMS — thermal hotspots near refineries (free, https://firms.modaps.eosdis.nasa.gov/api/area/)
# FIRMS_API_KEY=

# Resend — transactional magic-link login emails only. Get key at https://resend.com/
# (The former Daily Briefing / alert emails are disabled; OBSYD sends no product emails.)
# RESEND_API_KEY=

# Lemon Squeezy — UNUSED payment scaffolding. OBSYD is completely free (see README);
# these have no effect when unset and exist only for a possible future hosted tier.
# LEMONSQUEEZY_WEBHOOK_SECRET=
# LEMONSQUEEZY_CHECKOUT_URL=

# LLM (optional, BYOK) — used ONLY by the dormant GDELT news-sentiment collector,
# a non-power vertical disabled in the default power-only config. The active
# power/gas desk runs no LLM. Leave unset unless you re-enable news scoring.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# JWT expiry (default: 30 days)
# JWT_EXPIRY_DAYS=30
