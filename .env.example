# OBSYD Configuration
# Copy to .env and fill in your keys

# Database (default: SQLite)
DATABASE_URL=sqlite:///./obsyd.db

# EIA API (free, https://www.eia.gov/opendata/register.php)
EIA_API_KEY=

# FRED API (free, https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# Finnhub (BYOK, https://finnhub.io/)
FINNHUB_API_KEY=

# Alpha Vantage (BYOK, https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=

# AIS Stream (https://aisstream.io/)
AISSTREAM_API_KEY=

# AISHub (https://www.aishub.net/ - fallback AIS source)
AISHUB_API_KEY=

# NASA FIRMS (free, https://firms.modaps.eosdis.nasa.gov/api/area/)
FIRMS_API_KEY=

# LLM (BYOK - for sentiment analysis)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
